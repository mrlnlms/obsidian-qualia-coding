{
  "name": "qualia-coding",
  "version": "0.1.2",
  "description": "Qualitative data analysis for Obsidian",
  "main": "main.js",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "tsc -noEmit && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "wdio run wdio.conf.mts",
    "test:visual:update": "npx wdio run wdio.conf.mts -- --update-visual-baseline"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.29.0",
    "ag-grid-community": "^33.0.0",
    "chart.js": "^4.4.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-chart-wordcloud": "^4.4.5",
    "date-fns": "^4.1.0",
    "fabric": "^6.9.1",
    "fflate": "^0.8.2",
    "hyparquet": "^1.25.1",
    "hyparquet-compressors": "^1.1.1",
    "papaparse": "^5.4.1",
    "svd-js": "^1.1.1",
    "wavesurfer.js": "^7.0.0",
    "write-excel-file": "^4.0.4"
  },
  "devDependencies": {
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/papaparse": "^5.3.14",
    "@vitest/coverage-v8": "^4.1.0",
    "@wdio/cli": "^9.26.1",
    "@wdio/local-runner": "^9.26.1",
    "@wdio/mocha-framework": "^9.26.1",
    "@wdio/spec-reporter": "^9.26.1",
    "@wdio/visual-service": "^9.2.0",
    "esbuild": "^0.19.0",
    "jsdom": "^29.0.0",
    "obsidian": "^1.12.3",
    "obsidian-e2e-visual-test-kit": "github:mrlnlms/obsidian-e2e-visual-test-kit",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0",
    "wdio-obsidian-reporter": "^2.4.0",
    "wdio-obsidian-service": "^2.4.0"
  }
}

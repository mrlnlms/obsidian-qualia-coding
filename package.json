{
	"name": "obsidian-codemarker-v2",
	"version": "0.1.0",
	"description": "Qualitative text coding plugin for Obsidian using CodeMirror 6",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test:e2e": "wdio run wdio.conf.mts",
		"test:visual": "wdio run wdio.conf.mts --spec test/specs/visual.e2e.ts",
		"test:visual:update": "wdio run wdio.conf.mts --spec test/specs/visual.e2e.ts -- --updateBaseline"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"qualitative-coding",
		"codemirror"
	],
	"author": "m4rlon",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/mocha": "^10.0.10",
		"@types/node": "^16.11.6",
		"@wdio/cli": "^9.24.0",
		"@wdio/local-runner": "^9.24.0",
		"@wdio/mocha-framework": "^9.24.0",
		"@wdio/spec-reporter": "^9.24.0",
		"@wdio/visual-service": "^9.1.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"wdio-obsidian-reporter": "^2.3.2",
		"wdio-obsidian-service": "^2.3.2"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
